@page "/Identity/Account/Lockout"

<PageTitle>Locked out - SimpleModule</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full max-w-md">
        <div class="glass-card p-8">
            <header>
                <h1 class="alert-danger mb-4 text-sm">Locked out</h1>
