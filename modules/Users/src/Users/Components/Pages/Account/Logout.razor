@page "/Identity/Account/Logout"
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Logout> Logger
@inject NavigationManager Navigation

<PageTitle>Log out - SimpleModule</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full max-w-sm text-center">
        @if (HttpContext?.User?.Identity?.IsAuthenticated == true)
        {
            <div class="glass-card p-8">
                <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center bg-warning-bg">
                    <svg class="w-6 h-6 text-warning" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                </div>
                <h1 class="text-xl font-bold mb-2" style="font-family:'Sora',sans-serif;">Log out?</h1>
                <p class="text-sm text-text-muted mb-6">You'll need to sign in again to access your account.</p>
                <form method="post" @formname="logout" @onsubmit="OnSubmitAsync">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-primary w-full mb-3">Log out</button>
                </form>
                <a href="/" class="text-sm text-text-muted no-underline hover:text-text transition-colors">Cancel</a>
            </div>
        }
        else
        {
            <div class="glass-card p-8">
                <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center bg-success-bg">
                    <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                </div>
                <h1 class="text-xl font-bold mb-2" style="font-family:'Sora',sans-serif;">Logged out</h1>
                <p class="text-sm text-text-muted mb-6">You have been successfully logged out.</p>
                <a href="/Identity/Account/Login" class="btn-primary no-underline inline-block w-full">Sign in again</a>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private async Task OnSubmitAsync()
    {
        await SignInManager.SignOutAsync();
        Logger.LogInformation("User logged out.");
        Navigation.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
    }
}
