@page "/Identity/Account/RegisterConfirmation"
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Register confirmation - SimpleModule</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full max-w-md">
        <div class="glass-card p-8">
            <h1>Register confirmation</h1>
            @if (_displayConfirmAccountLink)
            {
                <p>
                    This app does not currently have a real email sender registered, see <a href="https://aka.ms/aspaccountconf">these docs</a> for how to configure a real email sender.
                    Normally this would be emailed: <a id="confirm-link" href="@_emailConfirmationUrl">Click here to confirm your account</a>
                </p>
            }
            else
            {
                <p>
                    Please check your email to confirm your account.
                </p>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool _displayConfirmAccountLink;
    private string? _emailConfirmationUrl;

    protected override async Task OnInitializedAsync()
    {
        if (Email is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);
        if (user is null)
        {
            return;
        }

        // Once you add a real email sender, you should remove this code that lets you confirm the account
        _displayConfirmAccountLink = true;
        if (_displayConfirmAccountLink)
        {
            var userId = await UserManager.GetUserIdAsync(user);
            var code = await UserManager.GenerateEmailConfirmationTokenAsync(user);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
            var returnUrl = ReturnUrl ?? "/";
            _emailConfirmationUrl = $"{Navigation.BaseUri}Identity/Account/ConfirmEmail?userId={Uri.EscapeDataString(userId)}&code={Uri.EscapeDataString(code)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
        }
    }
}

@using System.Text
@using Microsoft.AspNetCore.WebUtilities
