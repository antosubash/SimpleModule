# Build outputs
**/bin/
**/obj/
**/node_modules/
**/.vite/

# Vite output directories — regenerated from source by `npm run build` in
# Dockerfile stage 4. Excluding these prevents stale local build artifacts
# (e.g. files left over from a previous `assetFileNames` convention) from
# being baked into the image.
modules/*/src/SimpleModule.*/wwwroot/
template/SimpleModule.Host/wwwroot/js/

# Version control
.git/
.gitignore

# IDE / Editor
.vs/
.vscode/
.idea/
*.suo
*.user

# Tests (not needed for Host build)
tests/
!tests/e2e/package.json
!tests/k6/package.json
modules/*/tests/

# Development artifacts
*.db
*.db-shm
*.db-wal
.worktrees/

# Not needed in production image
SimpleModule.AppHost/
cli/
docs/
!docs/site/package.json
website/
!website/package.json

# CI/CD and tooling
.github/
.claude/

# Docker (avoid context recursion)
Dockerfile*
docker-compose*
.dockerignore
