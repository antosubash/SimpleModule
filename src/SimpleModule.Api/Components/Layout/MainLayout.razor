@inherits LayoutComponentBase
@inject NavigationManager Navigation

<HeadContent>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 0; background: #f5f5f5; color: #333; }
        .container { max-width: 480px; margin: 60px auto; padding: 32px; background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        h1, h2, h3, h4 { margin-top: 0; }
        .text-danger { color: #dc3545; }
        .form-group, .form-floating { margin-bottom: 16px; }
        label { display: block; margin-bottom: 4px; font-weight: 500; font-size: 14px; }
        input[type="email"], input[type="password"], input[type="text"], input[type="tel"] { width: 100%; padding: 10px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
        input:focus { outline: none; border-color: #0d6efd; box-shadow: 0 0 0 3px rgba(13,110,253,0.15); }
        .btn-primary, button[type="submit"] { display: inline-block; padding: 10px 24px; background: #0d6efd; color: #fff; border: none; border-radius: 4px; font-size: 14px; cursor: pointer; text-decoration: none; }
        .btn-primary:hover, button[type="submit"]:hover { background: #0b5ed7; }
        a { color: #0d6efd; }
        .validation-message { color: #dc3545; font-size: 12px; }
        nav { background: #212529; padding: 12px 24px; }
        nav a { color: #fff; text-decoration: none; margin-right: 16px; }
    </style>
</HeadContent>

<nav style="display:flex;align-items:center;">
    <div>
        <a href="/">SimpleModule</a>
        <a href="/swagger">API Docs</a>
    </div>
    <div style="margin-left:auto;">
        @if (HttpContext?.User?.Identity?.IsAuthenticated == true)
        {
            <a href="/Identity/Account/Manage" style="font-size:13px;opacity:0.8;">@HttpContext.User.Identity.Name</a>
        }
        else
        {
            <a href="/Identity/Account/Login" style="font-size:13px;opacity:0.8;">Login</a>
        }
    </div>
</nav>
<div class="container">
    @Body
</div>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }
}
