@page "/"

<PageTitle>Home - SimpleModule</PageTitle>

@if (IsAuthenticated)
{
    <!-- Dashboard View -->
    <div class="mb-6">
        <h1 class="text-2xl font-extrabold tracking-tight" style="font-family:'Sora',sans-serif;">
            Welcome back, <span class="gradient-text">@DisplayName</span>
        </h1>
        <p class="text-text-muted text-sm mt-1">Here's your development dashboard</p>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <a href="/Identity/Account/Manage" class="dash-card no-underline group">
            <div class="flex items-center gap-3 mb-3">
                <span class="w-9 h-9 rounded-xl flex items-center justify-center text-primary bg-primary-subtle">
                    <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </span>
                <span class="text-sm font-semibold text-text group-hover:text-primary transition-colors">Account</span>
            </div>
            <p class="text-xs text-text-muted">Manage your profile and security settings</p>
        </a>
        <a href="/swagger" class="dash-card no-underline group">
            <div class="flex items-center gap-3 mb-3">
                <span class="w-9 h-9 rounded-xl flex items-center justify-center text-accent bg-success-bg">
                    <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                </span>
                <span class="text-sm font-semibold text-text group-hover:text-primary transition-colors">API Docs</span>
            </div>
            <p class="text-xs text-text-muted">Explore endpoints and test requests</p>
        </a>
        <a href="/health/live" class="dash-card no-underline group">
            <div class="flex items-center gap-3 mb-3">
                <span class="w-9 h-9 rounded-xl flex items-center justify-center text-info bg-info-bg">
                    <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </span>
                <span class="text-sm font-semibold text-text group-hover:text-primary transition-colors">Health</span>
            </div>
            <p class="text-xs text-text-muted">Check system status and diagnostics</p>
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- User Info -->
        <div class="panel">
            <h2 class="panel-title">User Info</h2>
            <div class="glass-card p-5" id="user-info-card">
                <div class="text-text-muted text-sm flex items-center gap-2">
                    Loading user info<span class="spinner"></span>
                </div>
            </div>
        </div>

        <!-- Token Tester -->
        <div class="panel">
            <h2 class="panel-title">Token Tester</h2>
            <div class="glass-card p-5">
                <h3 class="text-sm font-semibold mb-1">OAuth2 Authorization Code + PKCE</h3>
                <p class="text-xs text-text-muted mb-4">
                    Obtain an access token using the <code class="bg-surface-raised px-1.5 py-0.5 rounded text-xs font-mono">simplemodule-client</code> application.
                </p>
                <button class="btn-primary btn-sm" id="btn-get-token" onclick="startOAuthFlow()">
                    Get Access Token
                </button>
                <div id="token-result" style="display:none">
                    <div class="code-block break-all max-h-30 mt-4" id="token-value"></div>
                    <h3 class="text-sm font-semibold mt-4 mb-2">Decoded Claims</h3>
                    <div class="overflow-auto rounded-xl border border-border">
                        <table id="token-claims"></table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- API Tester (full width) -->
    <div class="panel mt-2">
        <h2 class="panel-title">API Tester</h2>
        <div class="glass-card p-5">
            <h3 class="text-sm font-semibold mb-3">Call Protected Endpoints</h3>
            <div class="flex gap-2 flex-wrap mb-4">
                <button class="btn-outline btn-sm" onclick="callApi('/api/users/me')">GET /api/users/me</button>
                <button class="btn-outline btn-sm" onclick="callApi('/api/users')">GET /api/users</button>
                <button class="btn-outline btn-sm" onclick="callApi('/api/products')">GET /api/products</button>
                <button class="btn-outline btn-sm" onclick="callApi('/api/orders')">GET /api/orders</button>
            </div>
            <div id="api-status" class="text-xs text-text-muted mb-2 flex items-center gap-2"></div>
            <div class="code-block whitespace-pre-wrap max-h-50" id="api-response">Click an endpoint above to make a request.</div>
        </div>
    </div>

    <script suppress-error="BL9992">
        // --- Helpers ---
        function clearChildren(el) {
            while (el.firstChild) el.removeChild(el.firstChild);
        }

        function createInfoRow(label, value, monospace) {
            var row = document.createElement('div');
            row.className = 'flex justify-between items-center py-3 text-sm border-b border-border last:border-b-0';
            var lbl = document.createElement('span');
            lbl.className = 'text-text-muted text-xs uppercase tracking-wide';
            lbl.textContent = label;
            var val = document.createElement('span');
            val.className = monospace ? 'font-mono text-xs text-text-secondary' : 'font-medium text-text';
            val.textContent = value;
            row.appendChild(lbl);
            row.appendChild(val);
            return row;
        }

        function createSpinner() {
            var s = document.createElement('span');
            s.className = 'spinner';
            return s;
        }

        function createStatusBadge(ok, code) {
            var span = document.createElement('span');
            span.className = ok ? 'badge-success' : 'badge-danger';
            span.textContent = code;
            return span;
        }

        // --- User Info ---
        (async function loadUserInfo() {
            var card = document.getElementById('user-info-card');
            try {
                var res = await fetch('/api/users/me');
                if (!res.ok) throw new Error(res.status + ' ' + res.statusText);
                var data = await res.json();
                clearChildren(card);
                card.appendChild(createInfoRow('Name', data.displayName || data.name || '-', false));
                card.appendChild(createInfoRow('Email', data.email || '-', false));
                card.appendChild(createInfoRow('ID', data.id || '-', true));
                if (data.roles) {
                    card.appendChild(createInfoRow('Roles', Array.isArray(data.roles) ? data.roles.join(', ') : data.roles, false));
                }
            } catch (e) {
                clearChildren(card);
                var err = document.createElement('span');
                err.className = 'text-danger text-sm';
                err.textContent = 'Failed to load: ' + e.message;
                card.appendChild(err);
            }
        })();

        // --- OAuth PKCE Flow ---
        var accessToken = null;

        function generateCodeVerifier() {
            var arr = new Uint8Array(32);
            crypto.getRandomValues(arr);
            return btoa(String.fromCharCode.apply(null, arr)).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
        }

        async function generateCodeChallenge(verifier) {
            var data = new TextEncoder().encode(verifier);
            var hash = await crypto.subtle.digest('SHA-256', data);
            return btoa(String.fromCharCode.apply(null, new Uint8Array(hash))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
        }

        async function startOAuthFlow() {
            var btn = document.getElementById('btn-get-token');
            btn.disabled = true;
            clearChildren(btn);
            btn.appendChild(document.createTextNode('Authorizing'));
            btn.appendChild(createSpinner());

            var verifier = generateCodeVerifier();
            var challenge = await generateCodeChallenge(verifier);
            var state = crypto.randomUUID();

            sessionStorage.setItem('pkce_verifier', verifier);
            sessionStorage.setItem('pkce_state', state);

            var params = new URLSearchParams({
                response_type: 'code',
                client_id: 'simplemodule-client',
                redirect_uri: window.location.origin + '/oauth-callback',
                scope: 'openid profile email',
                state: state,
                code_challenge: challenge,
                code_challenge_method: 'S256'
            });

            window.location.href = '/connect/authorize?' + params.toString();
        }

        // Handle callback if we have a code in the URL
        (async function handleCallback() {
            var params = new URLSearchParams(window.location.search);
            var code = params.get('code');
            var state = params.get('state');
            if (!code) return;

            window.history.replaceState({}, '', '/');

            var verifier = sessionStorage.getItem('pkce_verifier');
            var savedState = sessionStorage.getItem('pkce_state');

            if (state !== savedState) {
                alert('OAuth state mismatch');
                return;
            }

            sessionStorage.removeItem('pkce_verifier');
            sessionStorage.removeItem('pkce_state');

            try {
                var res = await fetch('/connect/token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        grant_type: 'authorization_code',
                        client_id: 'simplemodule-client',
                        code: code,
                        redirect_uri: window.location.origin + '/oauth-callback',
                        code_verifier: verifier
                    })
                });

                if (!res.ok) throw new Error(res.status + ' ' + res.statusText);
                var data = await res.json();
                accessToken = data.access_token;
                showToken(accessToken);
            } catch (e) {
                alert('Token exchange failed: ' + e.message);
            }

            var btn = document.getElementById('btn-get-token');
            btn.disabled = false;
            btn.textContent = 'Get Access Token';
        })();

        function showToken(token) {
            document.getElementById('token-result').style.display = 'block';
            document.getElementById('token-value').textContent = token;

            try {
                var parts = token.split('.');
                var payload = JSON.parse(atob(parts[1].replace(/-/g,'+').replace(/_/g,'/')));
                var table = document.getElementById('token-claims');
                clearChildren(table);

                var headerRow = document.createElement('tr');
                var th1 = document.createElement('th');
                th1.textContent = 'Claim';
                var th2 = document.createElement('th');
                th2.textContent = 'Value';
                headerRow.appendChild(th1);
                headerRow.appendChild(th2);
                table.appendChild(headerRow);

                for (var key of Object.keys(payload)) {
                    var val = payload[key];
                    var display = (key === 'exp' || key === 'iat' || key === 'nbf')
                        ? new Date(val * 1000).toLocaleString()
                        : (typeof val === 'object' ? JSON.stringify(val) : String(val));

                    var tr = document.createElement('tr');
                    var td1 = document.createElement('td');
                    td1.textContent = key;
                    var td2 = document.createElement('td');
                    td2.textContent = display;
                    tr.appendChild(td1);
                    tr.appendChild(td2);
                    table.appendChild(tr);
                }
            } catch (e) { /* non-JWT token, skip decode */ }
        }

        // --- API Tester ---
        async function callApi(url) {
            var statusEl = document.getElementById('api-status');
            var responseEl = document.getElementById('api-response');

            clearChildren(statusEl);
            statusEl.appendChild(document.createTextNode('Calling ' + url));
            statusEl.appendChild(createSpinner());
            responseEl.textContent = '';

            var headers = {};
            if (accessToken) {
                headers['Authorization'] = 'Bearer ' + accessToken;
            }

            try {
                var res = await fetch(url, { headers: headers });

                clearChildren(statusEl);
                statusEl.appendChild(createStatusBadge(res.ok, String(res.status)));
                statusEl.appendChild(document.createTextNode(' ' + res.statusText + ' \u2014 ' + url));

                var text = await res.text();
                try {
                    responseEl.textContent = JSON.stringify(JSON.parse(text), null, 2);
                } catch (e) {
                    responseEl.textContent = text;
                }
            } catch (e) {
                clearChildren(statusEl);
                statusEl.appendChild(createStatusBadge(false, 'Error'));
                statusEl.appendChild(document.createTextNode(' ' + e.message));
                responseEl.textContent = e.message;
            }
        }
    </script>
}
else
{
    <!-- Landing View -->
    <div class="flex items-center justify-center min-h-[calc(100vh-16rem)]">
        <div class="text-center max-w-lg mx-auto">
            <div class="w-16 h-16 rounded-2xl mx-auto mb-6 flex items-center justify-center text-white text-2xl font-bold shadow-lg" style="background:linear-gradient(135deg,var(--color-primary),var(--color-accent));">S</div>
            <h1 class="text-4xl font-extrabold mb-3 tracking-tight" style="font-family:'Sora',sans-serif;">
                <span class="gradient-text">SimpleModule</span>
            </h1>
            <p class="text-text-muted text-base mb-8 max-w-sm mx-auto leading-relaxed">
                Modular monolith framework for .NET &mdash; AOT&#8209;compatible, zero&nbsp;reflection
            </p>

            <div class="flex gap-3 justify-center flex-wrap">
                <a href="/Identity/Account/Login" class="btn-primary btn-lg no-underline">Get Started</a>
                <a href="/Identity/Account/Register" class="btn-secondary btn-lg no-underline">Create Account</a>
            </div>

            @if (IsDevelopment)
            {
                <div class="alert-warning mt-6 text-left text-xs">
                    <strong class="block mb-1 text-warning">Quick Start (Development Only)</strong>
                    Email: <code class="bg-warning-bg px-1.5 py-0.5 rounded text-xs font-mono font-medium">admin@@simplemodule.dev</code>
                    &nbsp; Password: <code class="bg-warning-bg px-1.5 py-0.5 rounded text-xs font-mono font-medium">Admin123!</code>
                </div>
            }

            <div class="flex gap-5 justify-center mt-8 text-sm">
                <a href="/swagger" class="text-text-muted no-underline hover:text-primary transition-colors">API Docs</a>
                <span class="text-border">&middot;</span>
                <a href="/health/live" class="text-text-muted no-underline hover:text-primary transition-colors">Health Check</a>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private bool IsAuthenticated => HttpContext?.User?.Identity?.IsAuthenticated == true;
    private string DisplayName => HttpContext?.User?.Identity?.Name ?? "User";
    private bool IsDevelopment => Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
}
