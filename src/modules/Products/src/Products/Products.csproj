<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Library</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Bogus" />
    <ProjectReference Include="..\..\..\..\SimpleModule.Core\SimpleModule.Core.csproj" />
    <ProjectReference Include="..\..\..\..\SimpleModule.Database\SimpleModule.Database.csproj" />
    <ProjectReference Include="..\Products.Contracts\Products.Contracts.csproj" />
  </ItemGroup>
  <Target Name="JsBuild" BeforeTargets="Build" Condition="Exists('package.json') And (Exists('node_modules') Or Exists('$(MSBuildThisFileDirectory)..\..\..\..\..\..\node_modules'))">
    <Exec Command="npx vite build" WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
</Project>
