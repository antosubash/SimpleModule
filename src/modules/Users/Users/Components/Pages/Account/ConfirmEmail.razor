@page "/Identity/Account/ConfirmEmail"
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Confirm email - SimpleModule</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full max-w-md">
        <div class="glass-card p-8">
            <h1>Confirm email</h1>
            <StatusMessage Message="@_statusMessage" />
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? UserId { get; set; }

    [SupplyParameterFromQuery]
    public string? Code { get; set; }

    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        if (UserId is null || Code is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            _statusMessage = "Error confirming your email.";
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ConfirmEmailAsync(user, code);
        _statusMessage = result.Succeeded
            ? "Thank you for confirming your email."
            : "Error confirming your email.";
    }
}

@using System.Text
@using Microsoft.AspNetCore.WebUtilities
