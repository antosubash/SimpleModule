@page "/Identity/Account/Login"
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Log in - SimpleModule</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-14 h-14 rounded-2xl mx-auto mb-5 flex items-center justify-center text-white text-xl font-bold shadow-lg" style="background:linear-gradient(135deg,var(--color-primary),var(--color-accent));">S</div>
            <h1 class="text-2xl font-extrabold tracking-tight" style="font-family:'Sora',sans-serif;">Welcome back</h1>
            <p class="text-text-muted text-sm mt-1.5">Sign in to your account</p>
        </div>

        <div class="glass-card p-8">
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert-danger mb-4 text-sm" role="alert" />
                @if (_errors.Count > 0)
                {
                    <div class="alert-danger mb-4 text-sm" role="alert">
                        <ul class="list-none p-0 m-0 space-y-1">
                            @foreach (var error in _errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
                <div class="form-group">
                    <label for="Input.Email">Email</label>
                    <InputText @bind-Value="Input.Email" class="w-full" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                    <ValidationMessage For="() => Input.Email" class="text-danger" />
                </div>
                <div class="form-group">
                    <label for="Input.Password">Password</label>
                    <InputText @bind-Value="Input.Password" type="password" class="w-full" autocomplete="current-password" aria-required="true" placeholder="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;" />
                    <ValidationMessage For="() => Input.Password" class="text-danger" />
                </div>
                <div class="flex items-center justify-between mb-6">
                    <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer mb-0">
                        <InputCheckbox @bind-Value="Input.RememberMe" class="w-4 h-4 rounded border-border text-primary accent-primary" />
                        Remember me
                    </label>
                    <a href="/Identity/Account/ForgotPassword" class="text-xs text-text-muted hover:text-primary no-underline transition-colors">Forgot password?</a>
                </div>
                <button id="login-submit" type="submit" class="btn-primary btn-lg w-full">Log in</button>
            </EditForm>

            @if (_externalLogins.Count > 0)
            {
                <div class="relative my-6">
                    <hr />
                    <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-surface px-3 text-xs text-text-muted">or continue with</span>
                </div>
                <form id="external-account" action="/Identity/Account/ExternalLogin" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? "/")" />
                    <div class="flex gap-2 flex-wrap">
                        @foreach (var provider in _externalLogins)
                        {
                            <button type="submit" class="btn-secondary flex-1" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                        }
                    </div>
                </form>
            }
        </div>

        <div class="mt-6 text-center text-sm text-text-muted">
            Don't have an account?
            <a href="/Identity/Account/Register?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "/")" class="text-primary font-medium no-underline hover:underline">Sign up</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromForm]
    public InputModel Input { get; set; } = default!;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private IList<AuthenticationScheme> _externalLogins = [];
    private readonly List<string> _errors = [];

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        if (Environment.IsDevelopment())
        {
            Input.Email = "admin@simplemodule.dev";
            Input.Password = "Admin123!";
        }
        if (HttpContext is not null)
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
        _externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    }

    private async Task LoginUser()
    {
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            Navigation.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
            return;
        }
        if (result.RequiresTwoFactor)
        {
            Navigation.NavigateTo($"/Identity/Account/LoginWith2fa?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}&rememberMe={Input.RememberMe}", forceLoad: true);
            return;
        }
        if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            Navigation.NavigateTo("/Identity/Account/Lockout", forceLoad: true);
            return;
        }
        _errors.Add("Invalid login attempt.");
    }

    public sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}

@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
