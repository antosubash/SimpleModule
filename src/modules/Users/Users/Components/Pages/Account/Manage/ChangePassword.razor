@page "/Identity/Account/Manage/ChangePassword"
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<ChangePassword> Logger
@inject NavigationManager Navigation

<PageTitle>Change password - SimpleModule</PageTitle>

<h3>Change password</h3>
<StatusMessage Message="@_statusMessage" />
<div>
    <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="change-password">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" />
        @if (_errors.Count > 0)
        {
            <div class="text-danger" role="alert">
                <ul style="list-style:none;padding:0;">
                    @foreach (var error in _errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }
        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.OldPassword" type="password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Please enter your old password." />
            <label for="Input.OldPassword" class="form-label">Current password</label>
            <ValidationMessage For="() => Input.OldPassword" class="text-danger" />
        </div>
        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.NewPassword" type="password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please enter your new password." />
            <label for="Input.NewPassword" class="form-label">New password</label>
            <ValidationMessage For="() => Input.NewPassword" class="text-danger" />
        </div>
        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please confirm your new password." />
            <label for="Input.ConfirmPassword" class="form-label">Confirm new password</label>
            <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
        </div>
        <button type="submit" class="w-100 btn btn-lg btn-primary">Update password</button>
    </EditForm>
</div>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    public InputModel Input { get; set; } = default!;

    private string? _statusMessage;
    private readonly List<string> _errors = [];

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        var user = await UserManager.GetUserAsync(HttpContext!.User);
        if (user is null) { Navigation.NavigateTo("/Identity/Account/Login", forceLoad: true); return; }

        var hasPassword = await UserManager.HasPasswordAsync(user);
        if (!hasPassword)
        {
            Navigation.NavigateTo("/Identity/Account/Manage/SetPassword");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext!.User);
        if (user is null) return;

        var changePasswordResult = await UserManager.ChangePasswordAsync(user, Input.OldPassword, Input.NewPassword);
        if (!changePasswordResult.Succeeded)
        {
            foreach (var error in changePasswordResult.Errors)
            {
                _errors.Add(error.Description);
            }
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");
        _statusMessage = "Your password has been changed.";
    }

    public sealed class InputModel
    {
        [Required]
        [DataType(DataType.Password)]
        [Display(Name = "Current password")]
        public string OldPassword { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "New password")]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm new password")]
        [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
