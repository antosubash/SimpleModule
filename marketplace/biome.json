{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "root": false,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "warn",
        "noLabelWithoutControl": "warn",
        "useButtonType": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "modules/**",
      "packages/**",
      "template/**",
      "tests/**",
      "docs/**",
      "website/**",
      "!**/wwwroot",
      "!modules/*/src/*/types.ts",
      "!test-projects"
    ]
  }
}
