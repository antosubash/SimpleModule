<div id="app"></div>
<script id="inertia-page" type="application/json">@(new MarkupString(PageJson))</script>
<script type="module" src="/js/app.js?v=@CacheBuster"></script>

@code {
    private static readonly string CacheBuster = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString();

    [Parameter] public string PageJson { get; set; } = "";
}
